{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)",       "destination": "/dist/$1" }
  ],
  "crons": [
    { "path": "/api/hevy-sync", "schedule": "0 3 * * *" }
  ]
}
